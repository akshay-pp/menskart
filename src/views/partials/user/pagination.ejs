<nav aria-label="Page navigation">
    <ul class="pagination">

        <% if(page > 1) { %>

            <li class="page-item">
                <a class="page-link page-link-prev" href="?page=<%= page - 1 %>&sort=<%= sort %>&category=<%=  %>" aria-label="Previous" tabindex="-1" aria-disabled="true">
                    <span aria-hidden="true"><i class="icon-long-arrow-left"></i></span>Prev
                </a>
            </li>

        <% } %>
        
        <% for (let i = 1; i <= totalPages; i++) { %>

            <li class="page-item <%= page === i ? 'active' : '' %> " aria-current="page"><a class="page-link" href="?page=<%= i %>&sort=<%= sort %>&category=<%=  %>"><%= i %></a></li>
            
        <% } %>
        
        <li class="page-item-total">of <%= totalPages %></li>
            
        <% if(page < totalPages) { %>

            <li class="page-item">
                <a class="page-link page-link-next" href="?page=<%= page + 1 %>&sort=<%= sort %>&category=<%=  %>" aria-label="Next">
                    Next <span aria-hidden="true"><i class="icon-long-arrow-right"></i></span>
                </a>
            </li>

        <% } %>
    </ul>
</nav>