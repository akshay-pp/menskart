                                                <div id="collapse3-1" class="collapse show" aria-labelledby="heading3-1" data-parent="#accordion-3">
                                                    <div class="card-body row">
                                                        <div class="form-check border rounded col-sm-12 mb-2" id="add-new-address-from-checkout">
                                                            <h6 class="m-3"><a href="" class="text-success" data-toggle="modal" data-target="#add-address-modal"><i class="icon-plus"></i> ADD A NEW ADDRESS</a></h6>
                                                        </div>
                                                        <% address.forEach((address, index) => { %>
                                                            <div class="form-check border rounded col-sm-12 mb-1 address <%= index > 2 ? 'd-none' : '' %>">
                                                                <label class="form-check-label w-100" for="<%= address._id %>">
                                                                    <input class="form-check-input m-2" type="radio" name="shippingAddress" <%= index == 0 ? "checked" : "" %> id="<%= address._id %>" value="<%= address._id %>">
                                                                    <p class="mb-0 ml-5 badge badge-pill badge-light p-2"><%= address.type %></p>
                                                                    <div class="ml-5">
                                                                        <!-- <p class="mb-1 badge badge-dark text-white"><%= address.type %></p> -->
                                                                        <div class="d-flex">
                                                                            <p class="font-weight-normal mr-3"><%= address.name %></p>
                                                                            <p class="font-weight-normal"><%= address.phone %></p>
                                                                        </div>
                                                                        <p><%= address.address %></p>
                                                                        <p><%= address.city %>, <%= address.state %>, <%= address.pincode %></p>
                                                                    </div>                                                          
                                                                </label>
                                                            </div>
                                                        <% }) %>

                                                        <% if (address.length > 3) { %>
                                                            <div class="border rounded w-100 p-4" id="showMoreAddress"><h6 class="m-0 text-success cursor-pointer"><i class="icon-arrow-down"></i> show all <%= address.length %> addresses..</h6></div>
                                                        <% } %>
                                                        
                                                    </div><!-- End .card-body -->
                                                </div><!-- End .collapse -->
                                            </div><!-- End .card -->
                                    
