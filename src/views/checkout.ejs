    <!-- Main JS File -->
    <script src="/assets/js/main.js"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script type="module">

        import {showAlert, setError, setSuccess} from "/assets/js/fetch/validationHelpers.js";
        let paymentMethod, address, coupon;
        

        //show more address on click
        document.getElementById("showMoreAddress")?.addEventListener("click", function(){
            
            const address = document.querySelectorAll('.address');
            address.forEach(address => {
                if(address.classList.contains("d-none")){
                    address.classList.remove('d-none');
                }
            })

            this.classList.add("d-none");
        })




        //change maximum discount wrt coupon
        const checkBoxes = document.querySelectorAll('input[name="usableCoupons"]');
        checkBoxes.forEach(box => {
            box.addEventListener('change', function(){
                if (this.checked){
                    document.getElementById("maximum-savings").innerHTML = `₹${this.dataset.discount}`;
                }
            })
        })




        //apply coupon modal - only let one checkbox select and set maximum savings zero if none selected
        $('input[type="checkbox"]').on('change', function() {

            $('input[name="' + this.name + '"]').not(this).prop('checked', false);

            if ($('input[type="checkbox"]:checked').length === 0) {
                $('#maximum-savings').text('₹0');
            }

        });





        //load coupon info from sessionStorage
        document.addEventListener(`DOMContentLoaded`, async function(e){

            if (sessionStorage.getItem(`appliedCoupon`)) {

                let appliedCoupon = JSON.parse(sessionStorage.getItem(`appliedCoupon`))

                const response = await fetch ('/api/user/coupon/is-valid', {

                    method: 'POST',
                    headers: {'Content-Type' : 'application/json'},
                    body: JSON.stringify({couponCode: appliedCoupon.code})

                });

                const data = await response.json();

                if (data.success) {

                    document.getElementById('discountedAmount').textContent = `- ₹${appliedCoupon.discount}`
                    let subTotal = Number(document.getElementById('subTotal').textContent.replace("₹", ""));
                    document.getElementById('totalPrice').textContent = `₹${subTotal - appliedCoupon.discount}`;
                    document.getElementById('couponDiscount').classList.remove('d-none');



                    document.querySelector(`#apply-coupon-text`).textContent = `1 Coupon Applied`;
                    document.querySelector(`#coupon-info-text`).textContent = `You saved ₹${appliedCoupon.discount}`;
                    document.querySelector(`#coupon-info-text`).classList.remove(`d-none`);
                    document.querySelector(`#coupon-modal-btn`).textContent = `EDIT`;
                    document.getElementById(appliedCoupon.id).checked = true;



                    $('input[type="checkbox"]').not('#' + appliedCoupon.id).prop('checked', false);
                    let couponDiv = document.getElementById(`${appliedCoupon.id}-div`);
                    couponDiv.parentNode.insertBefore(couponDiv, couponDiv.parentNode.firstElementChild);
                    document.getElementById("maximum-savings").textContent = `₹${appliedCoupon.discount}`;
                
                } else {
                    sessionStorage.removeItem("appliedCoupon");
                }

            }

        })




        //check if coupon is valid and appropriate ui changes
        document.getElementById("check-coupon-form").addEventListener("submit", async function(e){
            
            e.preventDefault();

            const couponCode = document.getElementById("coupon-code-input").value.trim();

            // empty coupon code validation
            if(couponCode == ""){
                
                const element = document.getElementById("coupon-code-input");
                element.classList.add("is-invalid");
                element.classList.remove("is-valid");
                document.querySelector(".coupon-check").textContent = "Field Cant be empty";
                return;

            }
    

            const response = await fetch("/api/user/coupon/is-valid", {

                method: "POST",
                headers: {"Content-Type" : "application/json"},
                body: JSON.stringify({couponCode})

            })


            if (response.ok) {
                
                let data = await response.json();
                console.log({data});
                
                // validation feedback 
                const element = document.getElementById("coupon-code-input");
                element.classList.add("is-valid");
                element.classList.remove("is-invalid");

                // push "coupon appled" feedback
                document.getElementById(`apply-coupon-error`).style = `display-block`;
                document.getElementById(`apply-coupon-error`).className = `text-success font-weight-normal`;
                document.getElementById(`apply-coupon-error`).innerHTML = `<small><svg fill="#28a745" width="20px" height="20px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                <path fill-rule="evenodd" d="M12,2 C17.5228475,2 22,6.4771525 22,12 C22,17.5228475 17.5228475,22 12,22 C6.4771525,22 2,17.5228475 2,12 C2,6.4771525 6.4771525,2 12,2 Z M12,4 C7.581722,4 4,7.581722 4,12 C4,16.418278 7.581722,20 12,20 C16.418278,20 20,16.418278 20,12 C20,7.581722 16.418278,4 12,4 Z M15.2928932,8.29289322 L10,13.5857864 L8.70710678,12.2928932 C8.31658249,11.9023689 7.68341751,11.9023689 7.29289322,12.2928932 C6.90236893,12.6834175 6.90236893,13.3165825 7.29289322,13.7071068 L9.29289322,15.7071068 C9.68341751,16.0976311 10.3165825,16.0976311 10.7071068,15.7071068 L16.7071068,9.70710678 C17.0976311,9.31658249 17.0976311,8.68341751 16.7071068,8.29289322 C16.3165825,7.90236893 15.6834175,7.90236893 15.2928932,8.29289322 Z"/>
                                            </svg> Coupon ${data.coupon.code} is applied</small>`;
                
                
                

                
                // if coupon is listed, check it and push it to the first position on the list.
                // Else, append it to the first position on the list - else part UNFINISHED
                if (document.getElementById(data.coupon._id)) {

                    document.getElementById(data.coupon._id).checked = true;
                    $('input[type="checkbox"]').not('#' + data.coupon._id).prop('checked', false);
                    document.getElementById("maximum-savings").innerHTML = `₹${data.coupon.discount}`;


                    let couponDiv = document.getElementById(`${data.coupon._id}-div`);
                    couponDiv.parentNode.insertBefore(couponDiv, couponDiv.parentNode.firstElementChild);
                    
                } else {

                    let appendCoupon = `<div class="mb-0">
                                                <label class="form-check-label d-flex align-items-center mb-1" for="${data.coupon._id}">
                                                    <input class="form-check-input" type="checkbox" name="usableCoupons" id="${data.coupon._id}" value="${data.coupon.code}" checked data-discount="${data.coupon.discount}">
                                                    <div class="d-inline-block py-2 px-4 ml-4 font-weight-bold text-dark" style="border : 1px dashed #1b1b1b; border-radius: 8px">
                                                        ${data.coupon.code}
                                                    </div>                                                       
                                                </label>
                                                <span class="ml-4 d-block font-weight-normal text-success"><em>Save ₹${data.coupon.discount}</em> </span> 
                                                <span class="ml-4 d-block">${data.coupon.description}</span>
                                                <span class="ml-4">Expires on: </span><span class="font-weight-normal"><em>${data.coupon.expiry.toLocaleDateString("en-IN", {day: "2-digit", month: "long", year: "numeric"})}</em>
                                                </span> 
                                                <hr class="my-4">
                                            </div>`;
                    
                    
                    

                }
                
            } else {
                    
                const element = document.getElementById("coupon-code-input");
                element.classList.add("is-invalid");
                element.classList.remove("is-valid");

                if (response.status == "400") {
                    document.querySelector(".coupon-check").textContent = "Coupon invalid!";
                } else {
                    let data = await response.json();
                    document.querySelector(".coupon-check").textContent = data.error;
                }
                return;

            }

        })

        


        // apply coupon
        document.getElementById("apply-coupon-btn").addEventListener("click", async function(e){

            e.preventDefault()
            
            coupon = document.querySelector("input[type='checkbox'][name='usableCoupons']:checked");
            console.log(coupon);

            
            // if no coupon is selected/coupon removed
            //      1. push toast message
            //      2. clear coupon from local session storage
            //      3. reset form/modal when hidden

            // else
            //      1. change the apply coupon button to change and show coupon applied info
            //      2. coupon applied - toast message
            //      3. hide modal
            //      4. store coupon info in session storage

            if (!coupon) {
                
                document.querySelector(`#apply-coupon-text`).textContent = `Apply Coupon`;
                document.querySelector(`#coupon-info-text`).classList.add(`d-none`);
                document.querySelector(`#coupon-modal-btn`).textContent = `APPLY`;
                
                sessionStorage.removeItem("appliedCoupon");
                document.getElementById('couponDiscount').classList.add('d-none');

               
                document.getElementById('totalPrice').textContent = document.getElementById('subTotal').textContent;

                // clear modal when closed
                $(`#apply-coupon-modal`).on(`hidden.bs.modal`, function(e){
                    $(`#check-coupon-form`)[0].reset();
                    $(`#check-coupon-form`).find(`.form-control`).removeClass(`is-valid is-invalid`);
                    $(`#apply-coupon-error`).empty();
                })
                $(`#apply-coupon-modal`).modal(`hide`);

                // coupon rmeoved toast
                document.getElementById("toast-title").textContent = "Coupon removed";
                document.getElementById("remove").classList.remove("d-none");
                document.getElementById("apply").classList.add("d-none");
                $("#coupon-applied-toast").toast({delay: 3000});
                $("#coupon-applied-toast").toast('show');

            } else {
                document.getElementById("toast-title").textContent = "1 Coupon Applied";
                document.getElementById("apply").classList.remove("d-none");
                document.getElementById("remove").classList.add("d-none");

                $("#coupon-applied-toast").toast({delay: 3000});
                $("#coupon-applied-toast").toast('show');

                document.querySelector(`#apply-coupon-text`).textContent = `1 Coupon Applied`;
                document.querySelector(`#coupon-info-text`).textContent = `You saved ₹${coupon.dataset.discount}`;
                document.querySelector(`#coupon-info-text`).classList.remove(`d-none`);
                document.querySelector(`#coupon-modal-btn`).textContent = `EDIT`;
                $(`#apply-coupon-modal`).modal(`hide`);
                document.getElementById('discountedAmount').textContent = `- ₹${coupon.dataset.discount}`
                let subTotal = Number(document.getElementById('subTotal').textContent.replace("₹", ""));
                document.getElementById('totalPrice').textContent = `₹${subTotal - coupon.dataset.discount}`
                document.getElementById('couponDiscount').classList.remove('d-none');
                sessionStorage.setItem('appliedCoupon', JSON.stringify({id: coupon.id, code: coupon.value, discount: coupon.dataset.discount}));
            }

        })


        //add new address from the checkout page
        document.getElementById("add-address-form").addEventListener("submit", async function(e){

            e.preventDefault();
            $('#add-address-modal').modal('hide');
            const formData = new FormData(this);
            address = Object.fromEntries(formData);

            console.log(address);
            const response = await fetch("/api/user/profile/add-address", {

                method: "POST",
                headers: {"Content-Type": "application/json"},
                body: JSON.stringify(address)

            });

            const data = await response.json();
            showAlert(data, document.getElementById("checkout-error"));

            //attach newly added address to the checkout page
            if (data.success) {
                const htmlContent = `<div class="form-check border col-sm-12 mb-2">
                                                            <label class="form-check-label" for="${data.address._id}">
                                                                <input class="form-check-input m-2" type="radio" name="shippingAddress" id="${data.address._id}" value="${data.address._id}" checked>
                                                                <div class="p-4">
                                                                    <p class="mb-1 badge badge-dark text-white">${address.addressType}</p>
                                                                    <div class="d-flex">
                                                                        <p class="font-weight-normal mr-3">${address.addressName}</p>
                                                                        <p class="font-weight-normal">${address.addressPhone}</p>
                                                                    </div>
                                                                    <p>${address.addressTextarea}</p>
                                                                    <p>${address.addressCity}, ${address.addressState}, ${address.addressPincode}</p>
                                                                </div>                                                          
                                                            </label>
                                                        </div>`;

                document.getElementById("add-new-address-from-checkout").insertAdjacentHTML("afterend", htmlContent);
            }

        })




        //place order
        document.getElementById("place-order-btn").addEventListener("click", async function(e){

            e.preventDefault();

            //set shipping address
            const addressField = document.querySelector("input[type='radio'][name='shippingAddress']:checked");

            if (addressField) {
                address = addressField.value;
                console.log({address});
            } else {
                document.getElementById("checkout-error").innerHTML = "Please choose an address to proceed";
                document.getElementById("checkout-error").className = "alert alert-danger";
                document.getElementById("checkout-error").style.display = "block";
                return;
            }



            //set payment method
            paymentMethod = document.querySelector('input[type="radio"][name="payment-method"]:checked')?.value;
            console.log({paymentMethod});
            if (!paymentMethod) {
                console.log("no payment method")
                document.getElementById("checkout-error").innerHTML = "Please choose a payment method to proceed";
                document.getElementById("checkout-error").className = "alert alert-danger";
                document.getElementById("checkout-error").style.display = "block";
                return;
            }



            //api call
            const response = await fetch("/api/user/checkout", {
                method: "POST",
                headers: {"Content-Type" : "application/json"},
                body: JSON.stringify({paymentMethod, address, coupon: sessionStorage.getItem(`appliedCoupon`)})
            })

            const data = await response.json();

            if (!data.success) {
                if (response.status === 500) {
                    window.location.href = `/api/user/order-confirmation?status=error`;
                    return;
                }

                if (data.error) {
                    document.getElementById("checkout-error").innerHTML = data.error;
                    document.getElementById("checkout-error").className = "alert alert-danger";
                    document.getElementById("checkout-error").style.display = "block";
                }

                let errorList = '';
                data.errors.forEach(error => {
                    errorList += `<li>${error}</li>`;
                });

                console.log(errorList);
                document.getElementById("checkout-error").innerHTML = errorList;
                document.getElementById("checkout-error").className = "alert alert-danger";
                document.getElementById("checkout-error").style.display = "block";
            
            } else if (data.success && data.redirectUrl) {
                //if cash on delivery or wallet
                sessionStorage.removeItem("appliedCoupon");
                window.location.href = data.redirectUrl;
            } else if (data.success && data.razorpayOrder) {
                //if razorpay
                console.log(data.razorpayOrder);

                const options = {
                    "key": data.key, // Enter the Key ID generated from the Dashboard
                    "amount": data.razorpayOrder.amount, // Amount is in currency subunits. Default currency is INR. Hence, 50000 refers to 50000 paise
                    "currency": "INR",
                    "name": "Menskart INC",
                    "description": "Test Transaction",
                    "image": "https://example.com/your_logo",
                    "order_id": data.razorpayOrder.id , //This is a sample Order ID. Pass the `id` obtained in the response of Step 1
                    "handler": async function (response) {
                        const verifyResponse = await fetch('/api/user/verify-razorpay-payment', {
                            method: "POST",
                            headers: {"Content-Type" : "application/json"},
                            body: JSON.stringify(response)
                        });

                        const verifyData = await verifyResponse.json();
                        window.location.href = verifyData.redirectUrl;

                    },

                    "modal": {
                        "ondismiss": function() {
                            window.location.href = `/api/user/order-confirmation?status=error`;
                        }
                    },

                    "prefill": {
                        "name": data.prefill.name,
                        "email": data.prefill.email,
                        "contact": data.prefill.contact
                    },

                    "notes": {
                        "address": "Razorpay Corporate Office"
                    },

                    "theme": {
                        "color": "#0a0a0a"
                    }
                };

                const rzp = new Razorpay(options);
                rzp.open();
                // rzp1.on('payment.failed', function (response){
                //         alert(response.error.code);
                //         alert(response.error.description);
                //         alert(response.error.source);
                //         alert(response.error.step);
                //         alert(response.error.reason);
                //         alert(response.error.metadata.order_id);
                //         alert(response.error.metadata.payment_id);
                // });



            }


        })

        


    </script>
    <script>

        $('#add-address-modal').on('hidden.bs.modal', function () {
            $(this).find('input, textarea, select').val('');
        });

    </script>
</body>


