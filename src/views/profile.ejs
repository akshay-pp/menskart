<!DOCTYPE html>
<html lang="en">


<!-- molla/dashboard.html  22 Nov 2019 10:03:13 GMT -->
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Molla - Bootstrap eCommerce Template</title>
    <meta name="keywords" content="HTML5 Template">
    <meta name="description" content="Molla - Bootstrap eCommerce Template">
    <meta name="author" content="p-themes">
    <!-- Favicon -->
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/icons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/icons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/icons/favicon-16x16.png">
    <link rel="manifest" href="/assets/images/icons/site.html">
    <link rel="mask-icon" href="/assets/images/icons/safari-pinned-tab.svg" color="#666666">
    <link rel="shortcut icon" href="/assets/images/icons/favicon.ico">
    <meta name="apple-mobile-web-app-title" content="Molla">
    <meta name="application-name" content="Molla">
    <meta name="msapplication-TileColor" content="#cc9966">
    <meta name="msapplication-config" content="/assets/images/icons/browserconfig.xml">
    <meta name="theme-color" content="#ffffff">
    <!-- Plugins CSS File -->
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css">
    <!-- Main CSS File -->
    <link rel="stylesheet" href="/assets/css/style.css">
</head>

<body>
    <div class="page-wrapper">
        
        <%- include("./partials/user/header") %>

        <main class="main">
        	<div class="page-header text-center py-4" style="background-image: url('/assets/images/page-header-bg.jpg')">
        		<div class="container">
        			<h1 class="page-title">My Account</h1>
        		</div><!-- End .container -->
        	</div><!-- End .page-header -->
            <nav aria-label="breadcrumb" class="breadcrumb-nav mb-3">
                <div class="container">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="index.html">Home</a></li>
                        <li class="breadcrumb-item"><a href="#">Shop</a></li>
                        <li class="breadcrumb-item active" aria-current="page">My Account</li>
                    </ol>
                </div><!-- End .container -->
            </nav><!-- End .breadcrumb-nav -->

            <div class="page-content">
            	<div class="dashboard">
	                <div class="container">
	                	<div class="row">
	                		<aside class="col-md-3 col-lg-2 py-4">
	                			<ul class="nav nav-dashboard flex-column mb-3 mb-md-0" role="tablist">
								    <li class="nav-item">
								        <a class="nav-link active" id="tab-dashboard-link" data-toggle="tab" href="#tab-dashboard" role="tab" aria-controls="tab-dashboard" aria-selected="true">Dashboard</a>
								    </li>
                                    <% if (user) { %>
                                        <li class="nav-item">
                                            <a class="nav-link" id="tab-orders-link" data-toggle="tab" href="#tab-orders" role="tab" aria-controls="tab-orders" aria-selected="false">Orders</a>
                                        </li>
                                        <li class="nav-item">
                                            <a class="nav-link" id="tab-wallet-link" data-toggle="tab" href="#tab-wallet" role="tab" aria-controls="tab-wallet" aria-selected="false">Wallet</a>
                                        </li>
                                        <li class="nav-item">
                                            <a class="nav-link" id="tab-address-link" data-toggle="tab" href="#tab-address" role="tab" aria-controls="tab-address" aria-selected="false">Adresses</a>
                                        </li>
                                        <li class="nav-item">
                                            <a class="nav-link" id="tab-account-link" data-toggle="tab" href="#tab-account" role="tab" aria-controls="tab-account" aria-selected="false">Account Details</a>
                                        </li>
                                        <li class="nav-item">
                                            <a class="nav-link" href="#">Sign Out</a>
                                        </li>
                                    <% } %>
								</ul>
	                		</aside><!-- End .col-lg-3 -->

	                		<div class="col-md-9 col-lg-10">
	                			<div class="tab-content">
								    <div class="tab-pane fade show active" id="tab-dashboard" role="tabpanel" aria-labelledby="tab-dashboard-link">
								    	<% if (!user) { %>
                                            <p>Hello, You're <span class="font-weight-normal text-dark">not logged in. Please</span><span class="font-weight-normal text-dark"> <a href="/">Login</a></span>
                                                <br>
                                                From your account dashboard you can view your recent orders, manage your shipping and billing addresses, and edit your password and account details </p>
                                        <% } %>
								    </div><!-- .End .tab-pane -->

								    <div class="tab-pane fade" id="tab-orders" role="tabpanel" aria-labelledby="tab-orders-link">
                                        <div class="alert alert-danger" style="display: none;" id="orders-page-error" role="alert">
                                        </div>

                                        <div class="card-body">
                                            <div class="table-responsive">
                                                <table class="table table-hover">
                                                    <thead>
                                                        <tr>
                                                            <th>Product</th>
                                                            <th scope="col">Date</th>
                                                            <th scope="col">Amount</th>
                                                            <th scope="col">Order Status</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <% orders.forEach(order => { %>
                                                            <tr>
                                                                <td style="width: 50%;">
                                                                    <a class="itemside d-flex align-items-center" href="/api/user/order/<%= order._id %>/item/<%= order.orderItems._id %>">
                                                                        <div class="left px-3">
                                                                            <img src="/<%= order.orderItems.productData.images[0] %>" width="40" height="40" class="img-xs" alt="Item"/>
                                                                        </div>
                                                                        <div class="info mx-4 text-capitalize"><p><%= order.orderItems.productData.productname %></div>
                                                                    </a>
                                                                </td>
                                                                <td style="width: 20%;"><%= new Date(order.createdAt).toLocaleString("en-IN", { 
                                                                    day: "numeric", 
                                                                    month: "short", 
                                                                    year: "numeric"
                                                                }).replace(" at", ", ") %></td>
                                                                <td style="width: 20%;"><b>₹ <%= order.orderItems.price %></b></td>
                                                                <td style="width: 10%;">
                    
                                                                    <% if (order.orderItems.returnStatus != "none"){ %>
                                                                        <span class="badge rounded-pill alert-danger">Return <%= order.orderItems.returnStatus%></span>
                                                                    <% } else if (order.orderItems.status == "cancelled") { %>
                                                                        <span class="badge rounded-pill alert-danger">Cancelled</span>
                                                                    <% } else if (order.orderItems.status == "delivered") { %>
                                                                        <span class="badge rounded-pill alert-success">Delivered</span>
                                                                    <% } else { %>
                                                                        <span class="badge rounded-pill alert-warning"><%= order.orderItems.status %></span>
                                                                    <% } %>
                    
                                                                </td>
                                                                <!-- <td class="text-end">
                                                                    <a href="/api/admin/orders/<%# order._id %>" class="btn btn-md rounded font-sm">Detail</a>
                                                                    <div class="dropdown">
                                                                        <a href="#" data-bs-toggle="dropdown" class="btn btn-light rounded btn-sm font-sm"> <i class="material-icons md-more_horiz"></i> </a>
                                                                        <div class="dropdown-menu">
                                                                            <a class="dropdown-item" href="#">View detail</a>
                                                                            <a class="dropdown-item" href="#">Edit info</a>
                                                                            <a class="dropdown-item text-danger" href="#">Delete</a>
                                                                        </div>
                                                                    </div>
                                                                </td> -->
                                                            </tr>
                                                        <% }) %>
                                                    </tbody>
                                                </table>
                                            </div>
                                            <!-- table-responsive //end -->
                                        </div>

                                        <nav aria-label="Page navigation">
                                            <ul class="pagination">

                                                <% if(page > 1) { %>

                                                    <li class="page-item">
                                                        <a class="page-link page-link-prev" href="?page=<%= page - 1 %>" aria-label="Previous" tabindex="-1" aria-disabled="true">
                                                            <span aria-hidden="true"><i class="icon-long-arrow-left"></i></span>Prev
                                                        </a>
                                                    </li>

                                                <% } %>
                                                
                                                <% for (let i = 1; i <= totalPages; i++) { %>

                                                    <li class="page-item <%= page === i ? 'active' : '' %> " aria-current="page"><a class="page-link" href="?page=<%= i %>"><%= i %></a></li>
                                                    
                                                <% } %>
                                                
                                                <li class="page-item-total">of <%= totalPages %></li>
                                                    
                                                <% if(page < totalPages) { %>

                                                    <li class="page-item">
                                                        <a class="page-link page-link-next" href="?page=<%= page + 1 %>" aria-label="Next">
                                                            Next <span aria-hidden="true"><i class="icon-long-arrow-right"></i></span>
                                                        </a>
                                                    </li>

                                                <% } %>
                                            </ul>
							            </nav>
								    	
								    	<!-- <a href="category.html" class="btn btn-outline-primary-2"><span>GO SHOP</span><i class="icon-long-arrow-right"></i></a> -->
								    </div><!-- .End .tab-pane -->

								    <div class="tab-pane fade mx-4" id="tab-wallet" role="tabpanel" aria-labelledby="tab-wallet-link">
								    	<div class="d-flex bg-dark justify-content-between align-items-center mb-2" style="border: 1px solid #b1b1b1; border-radius: 8px;">
                                            <div class="p-5 d-flex flex-column align-items-end">
                                                <span class="text-white h6 mb-1">Current Wallet Balance</span>
                                                <h2 class="text-secondary mb-0">
                                                    <i class="icon-rupee"></i>2499.00
                                                </h2>
                                            </div>
                                            
                                            <div class="p-5 d-flex flex-column align-items-end">
                                                <span class="text-white h6 mb-1">Referral Earnings</span>
                                                <h3 class="text-secondary mb-0">
                                                    <i class="icon-rupee"></i>300.00
                                                </h3>
                                                <span class="text-white">Successfull Referrals: 3</span>
                                            </div>
                                        </div>

                                        <div class="mb-2" style="border: 1px solid #b1b1b1; border-radius: 8px; background: rgba(204, 153, 102, 0.1)">
                                            <div class="p-5 d-flex flex-column align-items-center">
                                                <h3>Refer a friend. Give <i class="icon-rupee"></i>200 Get <i class="icon-rupee"></i>200</h3>
                                                <span class="font-weight-normal">Invite a friend to Menskart. Your friend gets <i class="icon-rupee"></i>200 instantly and you get <i class="icon-rupee"></i>200 once he completes his first order</span>
                                            </div>

                                            <div class="d-flex justify-content-center mb-2">
                                                <div class="d-flex align-items-center bg-white" style="border: 1px dashed #A6C76C;">
                                                    <div class="px-5">referralcodesample</div>
                                                </div>
                                                <div class="btn btn-secondary">
                                                    <div class="p-2">Copy</div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="" style="border: 1px solid #b1b1b1; border-radius: 8px;">
                                            <h4 class="pl-5 mt-3 mb-0">Wallet Activity</h4>
                                            <div class="px-5 mb-0 mt-3">
                                                <table class="table">
                                                    <thead class="thead-light">
                                                        <tr>
                                                            <th scope="col" class="pl-4">Type</th>
                                                            <th scope="col">Source</th>
                                                            <th scope="col">Amount</th>
                                                            <th scope="col">Date</th>
                                                            <th scope="col">Status</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <tr>
                                                            <td class="pl-4"><span class="badge rounded-pill bg-secondary text-white font-weight-normal px-4 py-2">Credit</span></td>
                                                            <td>Refund OrderId: #178486</td>
                                                            <td class="h6 mb-0 text-success">+2499.00</td>
                                                            <td>Oct 25, 2025</td>
                                                            <td>Success</td>
                                                        </tr>
                                                        <tr>
                                                            <td class="pl-4"><span class="badge rounded-pill bg-danger text-white font-weight-normal px-4 py-2">Debit</span></td>
                                                            <td>Payment for OrderId: #17987686</td>
                                                            <td class="h6 mb-0 text-danger">-3699.00</td>
                                                            <td>Oct 17, 2025</td>
                                                            <td>Success</td>
                                                        </tr>
                                                        <tr>
                                                            <td class="pl-4"><span class="badge rounded-pill bg-secondary text-white font-weight-normal px-4 py-2">Credit</span></td>
                                                            <td>Referral Bonus</td>
                                                            <td class="h6 mb-0 text-success">+199.00</td>
                                                            <td>Oct 16, 2025</td>
                                                            <td>Success</td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>

								    	<a href="category.html" class="btn btn-outline-primary-2 d-none"><span>GO SHOP</span><i class="icon-long-arrow-right"></i></a>
								    </div><!-- .End .tab-pane -->

								    <div class="tab-pane fade" id="tab-address" role="tabpanel" aria-labelledby="tab-address-link">
								    	<p>The following addresses will be used on the checkout page by default.</p>
                                        <div class="row my-4">
                                            <div class="col-sm-6">
                                                <a href="" class="btn btn-outline-primary-2" data-toggle="modal" data-target="#add-address-modal"><i class="icon-plus"></i>ADD A NEW ADDRESS</a>
                                            </div>
                                        </div>
								    	<div class="row">
                                            <% if (address) { %>
                                                <% address.forEach(address => {  %>
                                                    <div class="col-lg-6">
                                                        <div class="card card-dashboard">
                                                            <div class="card-body">
                                                                <h3 class="card-title"><%= address.type %></h3><!-- End .card-title -->
        
                                                                <p><%= address.name %><br>
                                                                    <%= address.phone %><br>
                                                                    <%= address.address %><br>
                                                                    <%= address.pincode %><br>
                                                                    <%= address.city %><br>
                                                                    <%= address.state %><br>
                                                                <a href="#" id="edit-address-btn" data-toggle="modal" data-target="#edit-address-modal" class="btn btn-outline-primary-2" data-address="<%= JSON.stringify(address) %>">Edit <i class="icon-edit"></i></a>
                                                                <a href="#" id="delete-address-btn" data-toggle="modal" data-target="#delete-address-modal" class="btn btn-outline-danger" data-id="<%= address._id %>">Delete <i class="icon-close"></i></a></p>
                                                            </div><!-- End .card-body -->
                                                        </div><!-- End .card-dashboard -->
                                                    </div><!-- End .col-lg-6 -->
                                                <% }) %>
                                            <% } %>								    		                                       
								    	</div><!-- End .row -->
								    </div><!-- .End .tab-pane -->

								    <div class="tab-pane fade" id="tab-account" role="tabpanel" aria-labelledby="tab-account-link">
								    	<form action="#">
                                            <div class="alert alert-danger" style="display: none" id="update-name-error" role="alert">
                                                A simple danger alert—check it out!
                                            </div>
			                				<div class="row align-items-center mb-2">
			                					<div class="col-sm-6">
			                						<label>First Name *</label>
			                						<input type="text" class="form-control" name="firstname" id="edit-firstname" value="<%= user?.fullname.split(" ")[0] %>" required disabled>
			                					</div><!-- End .col-sm-6 -->

			                					<div class="col-sm-4">
			                						<label>Last Name *</label>
			                						<input type="text" class="form-control" id="edit-lastname" name="lastname" value="<%= user?.fullname.split(" ")[1] %>" required disabled>
			                					</div><!-- End .col-sm-6 -->
                                                <div class="col-sm-2 mt-2">
                                                    <a href="#" class="btn btn-outline-dark" id="name-edit-btn">Edit</a>
                                                </div>                                              
			                				</div><!-- End .row -->
                                        </form>

		            						<!-- <label>Display Name *</label>
		            						<input type="text" class="form-control" required>
		            						<small class="form-text">This will be how your name will be displayed in the account section and in reviews</small> -->
                                        <form>
                                            <div class="alert alert-danger" style="display: none" id="update-email-error" role="alert">
                                                A simple danger alert—check it out!
                                            </div>
                                            <div class="row align-items-center mb-2">
			                					<div class="col-sm-6">
			                						<label>Email address *</label>
		        							        <input type="email" id="edit-email" name="email" class="form-control" value="<%= user?.email %>" required disabled>
			                					</div><!-- End .col-sm-6 -->
                                                <div class="col-sm-2 mt-2">
                                                    <a class="btn btn-outline-dark"  id="email-edit-btn" data-toggle="modal" data-target="#email-updation-modal">Edit</a>
                                                </div>
                                            </div>
                                        </form>

                                        <form>
                                            <div class="alert alert-danger" style="display: none" id="update-phone-error" role="alert">
                                                A simple danger alert—check it out!
                                            </div>
                                            <div class="row align-items-center mb-2">
			                					<div class="col-sm-6">
			                						<label>Phone *</label>
		        							        <input type="email" id="edit-phone" name="phone" class="form-control" value="<%= user?.phone %>" required disabled>
			                					</div><!-- End .col-sm-6 -->
                                                <div class="col-sm-2  mt-2">
                                                    <a href="#" id="phone-edit-btn" class="btn btn-outline-dark">Edit<i class="icon-edit"></i></a>
                                                </div>                                              
			                				</div><!-- End .row -->
                                        </form>

		                					<!-- <button type="submit" class="btn btn-outline-primary-2">
			                					<span>SAVE CHANGES</span>
			            						<i class="icon-long-arrow-right"></i>
			                				</button> -->

								    </div><!-- .End .tab-pane -->
								</div>
	                		</div><!-- End .col-lg-9 -->
	                	</div><!-- End .row -->
	                </div><!-- End .container -->
                </div><!-- End .dashboard -->
            </div><!-- End .page-content -->


            <!-- email updation modal -->
            <div class="modal fade" id="email-updation-modal" tabindex="-1" role="dialog" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered" >
                    <div class="modal-content">
                        <div class="modal-body">
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true"><i class="icon-close"></i></span>
                            </button>
        
                            <div class="form-box" id="email-verify-otp">
                                <div class="form-tab">
                                    <ul class="nav nav-pills nav-fill nav-border-anim" role="tablist">
                                        <li class="nav-item">
                                            <a class="nav-link active" id="signin-tab" data-toggle="tab" role="tab" aria-controls="signin" aria-selected="true">Update Email</a>
                                        </li>
                                    </ul>
                                    <div class="tab-content" id="tab-content-5">
                                        <div class="tab-pane fade show active" id="signin" role="tabpanel" aria-labelledby="signin-tab">


                                            <!-- email update form -->
                                            <form action="#" id="update-email-form">
                                                <div class="alert alert-danger" style="display: none" id="email-update-error" role="alert">
                                                    A simple danger alert—check it out!
                                                </div>
                                                <div class="form-group">
                                                    <label for="updated-email">Enter new email </label>
                                                    <input type="text" class="form-control" id="updated-email" name="updatedEmail" required>
                                                </div><!-- End .form-group -->
        
                                                <div class="form-footer d-flex justify-content-between">
                                                    <button type="submit" class="btn btn-outline-primary-2" id="send-otp-btn">
                                                        <span>Send OTP</span>
                                                        <i class="icon-long-arrow-right"></i>
                                                    </button>
                                                </div><!-- End .form-footer -->
                                            </form>


                                            <!-- otp verification form -->
                                            <form action="#" style="display: none;" id="email-verif-otp">
                                                <div class="alert alert-danger" style="display: none" id="updateEmail-otp-error" role="alert">
                                                    A simple danger alert—check it out!
                                                </div>
                                                <div class="form-group">
                                                    <label for="otp-old-email">Enter otp sent to old email </label>
                                                    <input type="text" class="form-control" id="otp-old-email" name="otpOld" required>
                                                </div><!-- End .form-group -->
                                                
                                                <div class="form-group">
                                                    <label for="otp-received">Enter otp sent to new email</label>
                                                    <input type="text" class="form-control" id="otp-new-email" name="otpNew" required>
                                                </div><!-- End .form-group -->
        
                                                <div class="form-footer d-flex justify-content-between">
                                                    <button type="submit" class="btn btn-outline-primary-2" id="verify-otp-btn">
                                                        <span>Verify</span>
                                                        <i class="icon-long-arrow-right"></i>
                                                    </button>
        
                                                    <div>
                                                        <a href="#" class="forgot-link mx-4" id="resend-otp-timer"></a>
                                                        <button class="btn btn-outline-primary" id="resend-otp" disabled >Resend OTP</button>
                                                    </div>
                                                </div><!-- End .form-footer -->
                                            </form>
                                        </div><!-- .End .tab-pane -->
                                    </div><!-- End .tab-content -->
                                </div><!-- End .form-tab -->
                            </div><!-- End .form-box -->    
                        </div><!-- End .modal-body -->
                    </div><!-- End .modal-content -->
                </div><!-- End .modal-dialog -->
            </div><!-- End .modal -->


            <!-- add address modal -->
            <div class="modal fade" id="add-address-modal" tabindex="-1" role="dialog" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered" >
                    <div class="modal-content">
                        <div class="modal-body">
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true"><i class="icon-close"></i></span>
                            </button>
        
                            <div class="form-box">
                                <div class="form-tab">
                                    <ul class="nav nav-pills nav-fill nav-border-anim" role="tablist">
                                        <li class="nav-item">
                                            <a class="nav-link active" id="add-address-tab" data-toggle="tab" role="tab" aria-controls="add-address-tab" aria-selected="true">Add New Address</a>
                                        </li>
                                    </ul>
                                    <div class="tab-content" id="tab-content-5">
                                        <div class="tab-pane fade show active" id="add-address" role="tabpanel" aria-labelledby="add-address-tab">


                                            <form action="#" id="add-address-form">
                                                <div class="alert alert-danger" style="display: none" id="add-address-error" role="alert">
                                                    A simple danger alert—check it out!
                                                </div>
                                                <div class="row">
                                                    <div class="form-group col-sm-6">
                                                        <label for="address-name">Name</label>
                                                        <input type="text" class="form-control" id="address-name" data-valid="name" name="addressName" required>
                                                        <div class="invalid-feedback">
                                                            Feedback message
                                                        </div>
                                                    </div><!-- End .form-group -->

                                                    <div class="form-group col-sm-6">
                                                        <label for="address-phone">Phone</label>
                                                        <input type="text" class="form-control" id="address-phone" data-valid="phone" name="addressPhone" required>
                                                        <div class="invalid-feedback">
                                                            Feedback message
                                                        </div>
                                                    </div><!-- End .form-group -->
                                                </div>

                                                <div class="form-group">
                                                    <label for="address-textarea">Address</label>
                                                    <textarea class="form-control" id="address-textarea" data-valid="address" name="addressTextarea" rows="3" required></textarea>
                                                    <div class="invalid-feedback">
                                                            Feedback message
                                                    </div>
                                                </div><!-- End .form-group -->

                                                <div class="row">
                                                    <div class="form-group col-sm-6">
                                                        <label for="address-pincode">Pincode</label>
                                                        <input type="text" class="form-control" id="address-pincode" data-valid="pincode" name="addressPincode" required>
                                                        <div class="invalid-feedback">
