<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <title>Nest Dashboard</title>
        <meta http-equiv="x-ua-compatible" content="ie=edge" />
        <meta name="description" content="" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta property="og:title" content="" />
        <meta property="og:type" content="" />
        <meta property="og:url" content="" />
        <meta property="og:image" content="" />
        <!-- Favicon -->
        <link rel="shortcut icon" type="image/x-icon" href="/assets/imgs/theme/favicon.svg" />
        <!-- Template CSS -->
        <link href="/assets/css/main.css?v=1.1" rel="stylesheet" type="text/css" />
        <style>
            .disabled-div {
                pointer-events: none; /* Blocks all mouse interactions */
                opacity: 0.6;         /* Visually dims the content */
                cursor: not-allowed;  /* Optional: Changes cursor to indicate disabled state */
            }
        </style>
    </head>

    <body>
        <div class="screen-overlay"></div>
        
        <%- include(`./partials/admin/aside`) %>

        <main class="main-wrap">
            
            <%- include(`./partials/admin/header`) %>

            <section class="content-main">
                <div class="content-header">
                    <div>
                        <h2 class="content-title card-title">Offers</h2>
                        <p>Manage Offers</p>
                    </div>
                    <div>
                        <input type="text" placeholder="Search Categories" class="form-control bg-white" />
                    </div>
                </div>
                <div class="card">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3">
                                <form id="createOfferForm">
                                    
                                    <div class="mb-4">
                                        <label for="offerName" class="form-label">Name</label>
                                        <input type="text" name="offerName" placeholder="Type here" class="form-control form-field create-offer" id="offerName"/>
                                        <div class="invalid-feedback">
                                            Feedback message
                                        </div>
                                    </div>

                                    <div class="mb-4 border rounded">
                                        <fieldset class="p-2">
                                            <legend class="mb-2">Applicable categories: </legend>
                                                
                                            <% categories.forEach(category => { %>
                                                <div class="">
                                                    <input type="checkbox" id="<%= category.name %>" name="appliesTo" value="<%= category._id %>"/>
                                                    <label for="<%= category.name %>"><%= category.name %></label>
                                                </div>
                                            <% }) %>
                                        </fieldset>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label" for="isPercentage">isPercentage? : </label>
                                        <input type="checkbox" name="isPercentage" id="isPercentage" class="form-check-input" checked>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label" for="offerAmount">Discount Amount</label>
                                        <input type="number" id="offerAmount" name="offerAmount" placeholder="&lt 100 if percentage" min="1" class="form-control form-field create-offer">
                                        <div class="invalid-feedback">
                                            Feedback message
                                        </div>
                                    </div>

                                    <div class="mb-4" id= 'maxDiscount-div'>
                                        <label class="form-label" for="maxDiscount">Maximum Discount</label>
                                        <input type="number" id="maxDiscount" name="maxDiscount" placeholder="Maximum coupon discount" min="1" class="form-control form-field create-offer">
                                        <div class="invalid-feedback">
                                            Feedback message
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label" for="minimumValue">Minimum Product Value</label>
                                        <input type="number" id="minimumValue" name="minimumValue" placeholder="Type here" min="1" class="form-control form-field create-offer">
                                        <div class="invalid-feedback">
                                            Feedback message
                                        </div>
                                    </div>
                                    
                                    <div class="mb-4">
                                        <label class="form-label" for="offerStartDate">Valid from: </label>
                                        <input type="date" name="offerStartDate" id="offerStartDate" class="form-control form-field create-offer">
                                        <div class="invalid-feedback">
                                            Feedback message
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label" for="offerExpiryDate">Expires on: </label>
                                        <input type="date" name="offerExpiry" id="offerExpiryDate" class="form-control form-field create-offer">
                                        <div class="invalid-feedback">
                                            Feedback message
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label" for="offerdescription">Description</label>
                                        <textarea placeholder="Type here" class="form-control form-field create-offer" id="offerdescription" name="offerdescription"></textarea>
                                        <div class="invalid-feedback">
                                            Feedback message
                                        </div>
                                    </div>
                                    
                                    <div class="d-grid">
                                        <button class="btn btn-primary" type="submit">Create Offer</button>
                                    </div>

                                </form>
                           </div>
                            <div class="col-md-9">
                                <div class="table-responsive">
                                    <table class="table table-hover">
                                        <thead>
                                            <tr>
                                                <th class="text-center">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" value="" />
                                                    </div>
                                                </th>
                                                <th>Offer</th>
                                                <th>Discount</th>
                                                <th>Min. Value</th>
                                                <th>isActive</th>
                                                <th>Valid until</th>
                                                <th class="text-end">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% offers.forEach(offer => { %>
                                            <tr>
                                                <td class="text-center">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" value="" />
                                                    </div>
                                                </td>
                                                <td><%= offer.name %></td>
                                                <td><%= !offer.isPercent ? "₹" : "" %><%= offer.offerAmount %><%= offer.isPercent ? "%" : "" %></td>
                                                <td><b>₹<%= offer.minimumValue %></b></td>
                                                
                                                <td><%= offer.isActive %></td>
                                                <td><%= offer.expiry.toISOString().split("T")[0] %></td>
                                                <td class="text-end">
                                                    <div class="dropdown">
                                                        <a href="#" data-bs-toggle="dropdown" class="btn btn-light rounded btn-sm font-sm"> <i class="material-icons md-more_horiz"></i> </a>
                                                        <div class="dropdown-menu">
                                                            <a href="#" data-bs-toggle="modal" data-bs-target="#disable-offer-modal" data-offer="<%= offer.isActive %>" class= "<%= offer.isActive ? "dropdown-item text-danger" : "dropdown-item text-success" %> disable-offer-modal-btn" id="<%= offer._id %>"> <%= offer.isActive ? "Disable" : "Enable" %></a>
                                                            <!-- <a class="dropdown-item text-danger" href="#">Disable</a> -->
                                                            <a class="dropdown-item edit-offer-btn" href="#" data-bs-toggle="modal" data-bs-target="#edit-offer-modal" data-offer="<%= JSON.stringify(offer) %>">Edit info</a>
                                                            <!-- <a class="dropdown-item text-danger" href="#">Delete</a> -->
                                                        </div>
                                                    </div>
                                                    <!-- dropdown //end -->
                                                </td>
                                            </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <!-- .col// -->
                        </div>
                        <!-- .row // -->
                    </div>
                    <!-- card body .// -->
                </div>
                <!-- card .// -->
            </section>

            <div class="modal fade" id="edit-offer-modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                        <h1 class="modal-title fs-5" id="staticBackdropLabel">Edit Offer</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body px-4 card" id ="delete-modal-content"> 
                            <div class="col-md-12">
                                <form id="editOfferForm">
                                    <div class="mb-4">
                                        <label for="editOfferName" class="form-label">Name</label>
                                        <input type="text" name="editOfferName" placeholder="Type here" class="form-control" id="editOfferName"/>
                                        <div class="invalid-feedback">
                                            Feedback message
                                        </div>
                                    </div>

                                    <div class="mb-4 border rounded">
                                        <fieldset class="p-2">
                                            <legend class="mb-2">Applicable categories: </legend>
                                                
                                            <% categories.forEach(category => { %>
                                                <div class="">
                                                    <input type="checkbox" id="edit-<%= category.name %>" name="editAppliesTo" value="<%= category._id %>"/>
                                                    <label for="edit-<%= category.name %>"><%= category.name %></label>
                                                </div>
                                            <% }) %>
                                        </fieldset>
                                    </div>
                                    
                                    <div class="d-flex mx-2 gap-3 justify-content-center align-items-center">
                                        <div class="mb-0 col-6">
                                            <label class="form-label" for="editIsPercentage">isPercentage? : </label>
                                            <input type="checkbox" name="editIsPercentage" id="editIsPercentage" class="form-check-input" checked>
                                        </div>

                                        <div class="mb-4 col-6" id= 'edit-maxDiscount-div'>
                                            <label class="form-label" for="editMaxDiscount">Maximum Discount</label>
                                            <input type="number" id="editMaxDiscount" name="editMaxDiscount" placeholder="Maximum coupon discount" min="1" class="form-control form-field edit-offer">
                                            <div class="invalid-feedback">
                                                Feedback message
                                            </div>
                                        </div>
                                    </div>

                                    <div class="d-flex mx-2 gap-3 justify-content-center">
                                        <div class="mb-4 col-6">
                                            <label class="form-label" for="editOfferAmount">Discount Amount</label>
                                            <input type="number" id="editOfferAmount" name="editOfferAmount" placeholder="&lt 100 if percentage" min="1" class="form-control form-field edit-offer">
                                            <div class="invalid-feedback">
                                                Feedback message
                                            </div>
                                        </div>
    
                                        <div class="mb-4 col-6">
                                            <label class="form-label" for="editMinimumValue">Minimum Product Value</label>
                                            <input type="number" id="editMinimumValue" name="editMinimumValue" placeholder="Type here" min="1" class="form-control form-field edit-offer">
                                            <div class="invalid-feedback">
                                                Feedback message
                                            </div>
                                        </div>
                                    </div>

                                    
                                    <div class="d-flex mx-2 gap-3 justify-content-center">
                                        <div class="mb-4 col-6">
                                            <label class="form-label" for="editOfferStartDate">Valid from: </label>
                                            <input type="date" name="editOfferStartDate" id="editOfferStartDate" class="form-control form-field edit-offer">
                                            <div class="invalid-feedback">
                                                Feedback message
                                            </div>
                                        </div>
    
                                        <div class="mb-4 col-6">
                                            <label class="form-label" for="editOfferExpiryDate">Expires on: </label>
                                            <input type="date" name="editOfferExpiry" id="editOfferExpiryDate" class="form-control form-field edit-offer">
                                            <div class="invalid-feedback">
                                                Feedback message
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label" for="editOfferDescription">Description</label>
                                        <textarea placeholder="Type here" class="form-control form-field edit-offer" id="editOfferDescription" name="editOfferDescription"></textarea>
                                        <div class="invalid-feedback">
                                            Feedback message
                                        </div>
                                    </div>
                                    
                                    <div class="d-grid">
                                        <button class="btn btn-primary" type="submit">Apply Changes</button>
                                    </div>

                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="disable-offer-modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered ">
                <div class="modal-content">
                    <div class="modal-header">
                    <h1 class="modal-title fs-5" id="disable-modal-header">Are you sure?</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="alert alert-danger" style="display: none" id="disable-offer-error" role="alert">
                        A simple danger alert—check it out!
                    </div>
                    <div class="modal-body fs-6" id ="disable-offer-content"> Hello
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <form action="#" method="POST" id= "confirm-disable-form">
                            <button type="submit" class="btn btn-danger" id="confirm-disable-btn" >Confirm Unlist</button>
                        </form>
                    </div>
                </div>
                </div>
            </div>

            <div class="toast" id="cart-page-toast" role="alert" aria-live="assertive" aria-atomic="true" style="position: fixed; bottom: 2rem; right: 1rem; z-index: 1055; width: 400px;">
                <div class="toast-header bg-dark text-white justify-content-between" id="toast-header">

                    <div class="d-flex p-2">
                        
                        <svg id="success-toast" class="d-none toast-icon" fill="#28a745" width="20px" viewBox="0 0 32 32" version="1.1" xmlns="http://www.w3.org/2000/svg">
                            <title>checkmark</title>
