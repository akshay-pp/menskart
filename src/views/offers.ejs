                        <span class="ms-3" id="toast-title" style="font-size: 14px;">Notification</span>

                    </div>

                    <button type="button" class="ms-2 mb-1 btn btn-outline-light" data-dismiss="toast" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            </div>

            <!-- content-main end// -->
            <footer class="main-footer font-xs">
                <div class="row pb-30 pt-15">
                    <div class="col-sm-6">
                        <script>
                            document.write(new Date().getFullYear());
                        </script>
                        &copy; Nest - HTML Ecommerce Template .
                    </div>
                    <div class="col-sm-6">
                        <div class="text-sm-end">All rights reserved</div>
                    </div>
                </div>
            </footer>
        </main>

        <script type="module">

            import {
                emptyFieldCheck,
                hasMinimumLength,
                hasMaximumLength,
                setError,
                setSuccess,
                isEmpty,
                triggerToast
            } from "/assets/js/fetch/validationHelpers.js"



            document.addEventListener('DOMContentLoaded', editOffer());

            function editOffer() {
                const fields = {
                    offerName: document.getElementById("editOfferName"),
                    isPercentage: document.getElementById("editIsPercentage"),
                    offerAmount: document.getElementById("editOfferAmount"),
                    maxDiscount: document.getElementById("editMaxDiscount"),
                    minimumValue: document.getElementById("editMinimumValue"),
                    offerStartDate: document.getElementById("editOfferStartDate"),
                    offerExpiryDate: document.getElementById("editOfferExpiryDate"),
                    offerDescription: document.getElementById("editOfferDescription")
                }
                
                const editOfferModal = document.getElementById('edit-offer-modal');
                let offerId;


                //==================== pre-populate edit offer modal ====================// 
                editOfferModal.addEventListener('show.bs.modal', function(e) {
                    const button = e.relatedTarget;
                    const offer = JSON.parse(button.dataset.offer);
                    offerId = offer._id;
                    console.log(offer);
                    fields.offerName.value = offer.name;
                    fields.isPercentage.checked = offer.isPercent;
                    fields.offerAmount.value = offer.offerAmount;
                    fields.maxDiscount.value = offer.maxDiscount;
                    fields.minimumValue.value = offer.minimumValue;
                    fields.offerStartDate.valueAsDate = new Date(offer.validFrom);
                    fields.offerExpiryDate.valueAsDate = new Date(offer.expiry);
                    fields.offerDescription.value = offer.description;
                    
                    if (fields.isPercentage.checked) {
                        document.getElementById('edit-maxDiscount-div').classList.remove('disabled-div');
                    } else {
                        document.getElementById('edit-maxDiscount-div').classList.add('disabled-div');
                    }

                    document.querySelectorAll('input[type="checkbox"][name="editAppliesTo"]').forEach(checkbox => {
                        checkbox.checked = false;
                    });
    
                    offer.appliesTo.forEach(item => {
                        document.getElementById(`edit-${item.categName}`).checked = true;
                    })
                })




                //remove validation errors when closing modal
                editOfferModal.addEventListener('hidden.bs.modal', function() {
                    const elements = editOfferModal.querySelectorAll('.is-valid, .is-invalid');
                    elements.forEach(el => {
                        el.classList.remove('is-valid', 'is-invalid');
                    });
                })




                // toggle max discount wrt isPercentage
                fields.isPercentage.addEventListener('change', function () {

                    if (this.checked) {
                        document.getElementById('edit-maxDiscount-div').classList.remove('disabled-div')
                    } else {
                        document.getElementById('edit-maxDiscount-div').classList.add('disabled-div')
                    }

                })




                //disable previous dates
                fields.offerStartDate.min = new Date().toISOString().split('T')[0];
                fields.offerExpiryDate.min = new Date().toISOString().split('T')[0];

                

                //==================== blur validations ====================//

                
                // validation for empty field
                emptyFieldCheck("blur", ...document.querySelectorAll(".form-field.edit-offer"));


                //minimum maximum length validation
                fields.offerName.addEventListener("blur", function() {
                    if (isEmpty(this)) {
                        return setError(this, "field cant be empty");
                    }
                    
                    if (!hasMinimumLength(this, 6)){
                        return setError(this, "minimum 6 characters");
                    }
                    
                    if (!hasMaximumLength(this, 30)){
                        return setError(this, "maximum 30 characters");
                    }
                })
                

                fields.offerExpiryDate.addEventListener("blur", function() {
                    if (fields.offerStartDate.value && this.value < fields.offerStartDate.value) {
                        return setError(this, "select a higher date than start date");
                    }
                })


                fields.offerStartDate.addEventListener("blur", function() {
                    if (fields.offerExpiryDate.value && this.value > fields.offerExpiryDate.value) {
                        return setError(this, "select a lower date than expiry date");
                    }
                })


                //cross field validations
                fields.offerAmount.addEventListener("blur", function(){
                    
                    if (fields.isPercentage.checked) {
                        if(this.value.trim() > 100 || this.value.trim() < 0){
                            setError(this, "Invalid percentage value");
                            return;
                        }
                    } else {
                        if (this.value.trim() <= fields.minimumValue.value.trim()) {
                            setError(this, "Discount amount should be less than cart value");
                            return;
                        }
                    }

                });


                fields.maxDiscount.addEventListener('blur', function() {

                    if (fields.minimumValue.value.trim() && Number(fields.minimumValue.value.trim()) <= Number(this.value.trim())) {
                        setError(this, "not that much discount Mr Admin!");
                        return;
                    }

                });


                fields.minimumValue.addEventListener('blur', function() {

                    if (fields.maxDiscount.value.trim() && Number(fields.maxDiscount.value.trim()) >= Number(this.value.trim())) {
                        setError(this, "higher cart value please!");
                        return false;
                    }

                });


                document.getElementById("editOfferForm").addEventListener("submit", async function(e){

                    e.preventDefault();

                    if (fields.isPercentage.checked){
                        if(!emptyFieldCheck("submit", ...document.querySelectorAll(".form-field.edit-offer"))){
                            return;
                        };
                    } else {
                        if(!emptyFieldCheck("submit", ...document.querySelectorAll(".form-field.edit-offer:not(#editMaxDiscount)"))){
                            return;
                        };
                    };


                    let isValid = submitValidations(fields);

                    if (!isValid) {
                        document.querySelector('.is-invalid')?.focus();
                        return;
                    }


                    const appliesTo = Array.from(document.querySelectorAll("input[name='editAppliesTo']:checked")).map(box => ({categName: box.id.replace('edit-', ''), categId: box.value}));
                    

                    console.log({appliesTo});

                    const formData = new FormData(this);

                    const payload = Object.fromEntries(formData);
                    delete payload.editAppliesTo;
                    payload.editAppliesTo = appliesTo;
                    payload.type = 'category';
                    payload._id = offerId;
                    console.log({payload});

                    const response = await fetch("/api/admin/offers", {
                        method: "PATCH",
                        headers: {"Content-Type" : "application/json"},
                        body: JSON.stringify(payload)
                    })

                    const data = await response.json();
                    location.reload();
                    console.log(data);

                })

            }




            //==================== disable an offer ====================//

            const disbaleOfferButton = document.querySelectorAll(".disable-offer-modal-btn");
            disbaleOfferButton.forEach((button) => {

                button.addEventListener("click", async function(){

                    const offerId = this.id;
                    console.log({offerId});
                    const isActive = JSON.parse(this.getAttribute("data-offer"));
                    console.log({isActive});
                    if (!isActive){

                        document.getElementById("disable-modal-header").textContent = "Activate Offer?";
                        document.getElementById("disable-offer-content").textContent = `Are you sure you want to activate the offer?`;
                        document.getElementById("confirm-disable-btn").className = "btn btn-success text-white";
                        document.getElementById("confirm-disable-btn").textContent = "Activate";

                    }else {

                        document.getElementById("disable-modal-header").textContent = "Deactivate the offer?";
                        document.getElementById("disable-offer-content").textContent = `Are you sure you want to deactivate the the offer?`;
                        document.getElementById("confirm-disable-btn").className = "btn btn-danger";
                        document.getElementById("confirm-disable-btn").textContent = "Deactivate";

                    }

                    document.getElementById("confirm-disable-form").addEventListener("submit", async (e) => {
                        e.preventDefault();

                        const payload = isActive ? "Deactivate" : "Activate" ; 
                        console.log({payload, offerId});
                        const response = await fetch(`/api/admin/offers/unlist/${offerId}`, {
                            method : "POST",
                            headers : { "Content-Type" : "application/json" },
                            body : JSON.stringify({payload})
                        });

                        const data = await response.json();

                        if (!data.success) {
                            
                            document.getElementById("disable-offer-error").textContent = data.error;
                            document.getElementById("disable-offer-error").className = "alert alert-danger";
                            document.getElementById("disable-offer-error").style.display = "block";
                                    
                        } else {

                            document.getElementById("disable-offer-error").textContent = data.message;
                            document.getElementById("disable-offer-error").className = "alert alert-success";
                            document.getElementById("disable-offer-error").style.display = "block";
                            setTimeout(() => {
                                location.reload();
                            }, 1000);

                        }
                    })

                })
            });

            
            
            
            //==================== create offer ====================//


            // fields references
            const fields = {
                offerName: document.getElementById("offerName"),
                isPercentage: document.getElementById("isPercentage"),
                offerAmount: document.getElementById("offerAmount"),
                maxDiscount: document.getElementById("maxDiscount"),
                minimumValue: document.getElementById("minimumValue"),
                offerStartDate: document.getElementById("offerStartDate"),
                offerExpiryDate: document.getElementById("offerExpiryDate"),
                offerDescription: document.getElementById("offerdescription")
            }


            // toggle max discount wrt isPercentage
            fields.isPercentage.addEventListener('change', function () {

                if (this.checked) {
                    document.getElementById('maxDiscount-div').classList.remove('disabled-div')
                } else {
                    document.getElementById('maxDiscount-div').classList.add('disabled-div')
                }

            })


            //disable previous dates
            fields.offerStartDate.min = new Date().toISOString().split('T')[0];
            fields.offerExpiryDate.min = new Date().toISOString().split('T')[0];

            

            //==================== blur validations ====================//

            
            // validation for empty field
            emptyFieldCheck("blur", ...document.querySelectorAll(".form-field"));


            //minimum maximum length validation
            fields.offerName.addEventListener("blur", function() {

                if (isEmpty(this)) {
                    return setError(this, "field cant be empty");
                }
                
                if (!hasMinimumLength(this, 6)){
                    return setError(this, "minimum 6 characters");
                }
                
                if (!hasMaximumLength(this, 30)){
                    return setError(this, "maximum 30 characters");
                }

            })
            

            fields.offerExpiryDate.addEventListener("blur", function() {
                if (fields.offerStartDate.value && this.value < fields.offerStartDate.value) {
                    return setError(this, "select a higher date than start date");
                }
            })


            fields.offerStartDate.addEventListener("blur", function() {
                if (fields.offerExpiryDate.value && this.value > fields.offerExpiryDate.value) {
                    return setError(this, "select a lower date than expiry date");
                }
            })


            //cross field validations
            fields.offerAmount.addEventListener("blur", function(){
                
                if (fields.isPercentage.checked) {
                    if(this.value.trim() > 100 || this.value.trim() < 0){
                        setError(this, "Invalid percentage value");
                        return;
                    }
                } else {
                    if (this.value.trim() >= fields.minimumValue.value.trim()) {
                        setError(this, "Discount amount should be less than product price");
                        return;
                    }
                }

            });


            fields.maxDiscount.addEventListener('blur', function() {
                if (fields.minimumValue.value.trim() && Number(fields.minimumValue.value.trim()) <= Number(this.value.trim())) {
                    setError(this, "Max discount must be less than product price!");
                    return;
                }
            });


            fields.minimumValue.addEventListener('blur', function() {

                if (fields.maxDiscount.value.trim() && Number(fields.maxDiscount.value.trim()) >= Number(this.value.trim())) {
                    setError(this, "higher cart value please!");
                    return false;
                }

            });

            
            document.getElementById("createOfferForm").addEventListener("submit", async function(e){

                e.preventDefault();


                if (fields.isPercentage.checked){
                    if (!emptyFieldCheck("submit", ...document.querySelectorAll(".form-field.create-offer"))) {
                        document.querySelector('.is-invalid')?.focus();
                        return;
                    }
                } else {
                    if (!emptyFieldCheck("submit", ...document.querySelectorAll(".form-field.create-offer:not(#maxDiscount)"))) {
                        document.querySelector('.is-invalid')?.focus();
                        return;
                    }
                }

                let isValid = submitValidations(fields);

                if (!isValid) {
                    document.querySelector('.is-invalid')?.focus();
                    return;
                }


                const appliesTo = Array.from(document.querySelectorAll("input[name='appliesTo']:checked")).map(box => ({categName: box.id, categId: box.value}));
                

                console.log({appliesTo});

                const formData = new FormData(this);

                const payload = Object.fromEntries(formData);
                delete payload.appliesTo;
                payload.appliesTo = appliesTo;
                payload.type = 'category';
                console.log(payload);

                const response = await fetch("/api/admin/offers", {
                    method: "POST",
                    headers: {"Content-Type" : "application/json"},
                    body: JSON.stringify(payload)
                })

                const data = await response.json();
                location.reload();
                console.log(data);

            })





            function submitValidations(fields) {
                let isValid = true;

                [fields.offerName].forEach(field => {
                
                    if (isEmpty(field)) {
                        setError(field, "field cant be empty");
                        isValid = false;
                    } else if (!hasMinimumLength(field, 6)) {
                        setError(field, "minimum 6 characters");
                        isValid = false;
                    } else if (!hasMaximumLength(field, 15)) {
                        setError(field, "maximum 15 characters");
                        isValid = false;
                    }

                });


                if (fields.isPercentage.checked) {
                
                    if (fields.offerAmount.value.trim() > 100 || fields.offerAmount.value.trim() < 0) {
                        setError(fields.offerAmount, "Invalid percentage value");
                        isValid = false;
                    }

                    if (fields.minimumValue.value && fields.maxDiscount.value && Number(fields.minimumValue.value.trim()) <= Number(fields.maxDiscount.value.trim())) {
                        setError(fields.maxDiscount, "Discount cant be higher than cart value");
                        isValid = false;
                    }

                } else {

                    if (fields.offerAmount.value && fields.minimumValue.value && Number(fields.offerAmount.value.trim()) >= Number(fields.minimumValue.value.trim())) {
                        setError(fields.offerAmount, "Discount amount should be less than cart value");
                        isValid = false;
                    }

                }


                if (fields.offerExpiryDate.value < fields.offerStartDate.value) {
                    setError(fields.offerExpiryDate, "select a higher date than start date")
                    isValid = false;
                }

                return isValid
                
            };


        </script>
        <script src="/assets/js/vendors/jquery-3.6.0.min.js"></script>
        <script src="/assets/js/vendors/bootstrap.bundle.min.js"></script>
        <script src="/assets/js/vendors/select2.min.js"></script>
        <script src="/assets/js/vendors/perfect-scrollbar.js"></script>
        <script src="/assets/js/vendors/jquery.fullscreen.min.js"></script>
        <!-- Main Script -->
        <script src="/assets/js/main.js?v=1.1" type="text/javascript"></script>
    </body>
</html>
