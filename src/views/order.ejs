        <!-- return modal -->
        <div class="modal fade" id="return-order-modal" tabindex="-1" role="dialog" aria-labelledby="returnOrderModal" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header bg-dark p-3 mb-0">
                        <h5 class="modal-title text-white" id="return-order-header">
                            <%=allowedAction%> this order?</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                </div>
                <div class="modal-body my-4">

                    <div class="m-4 <%= allowedAction == "return" ? "d-none" : "" %>">
                        <div class="d-flex align-items-center mb-1">
                            <p class="h6 mb-0">Are you sure you want to cancel this order?</p>
                        </div>
                    </div>
                    <div class="m-4 ml-5 <%= allowedAction == "cancel" ? "d-none" : "" %>">
                        <div class="form-check d-flex align-items-center mb-1">
                            <input class="form-check-input" type="radio" name="returnReason" id="returnReason1" value="broken">
                            <label class="form-check-label ml-3 font-weight-normal" for="returnReason1">
                                Received broken/damaged item
                            </label>
                        </div>
    
                        <div class="form-check d-flex align-items-center mb-1">
                            <input class="form-check-input" type="radio" name="returnReason" id="returnReason2" value="wrong">
                            <label class="form-check-label ml-3 font-weight-normal" for="returnReason2">
                                Received wrong item
                            </label>
                        </div>
    
                        <div class="form-check d-flex align-items-center mb-1">
                            <input class="form-check-input" type="radio" name="returnReason" id="returnReason3" value="defective">
                            <label class="form-check-label ml-3 font-weight-normal" for="returnReason3">
                                The product received is defective
                            </label>
                        </div>
    
                        <div class="form-check d-flex align-items-center mb-1">
                            <input class="form-check-input" type="radio" name="returnReason" id="returnReason4" value="missing">
                            <label class="form-check-label ml-3 font-weight-normal" for="returnReason4">
                                The product is missing in the package
                            </label>
                        </div>
    
                        <div class="form-check d-flex align-items-center mb-1">
                            <input class="form-check-input" type="radio" name="returnReason" id="returnReason5" value="other">
                            <label class="form-check-label ml-3 font-weight-normal" for="returnReason5">
                                Other (specify)
                            </label>
                        </div>
                        
                        <div class="form-group d-none" id="returnReasonTextarea-div">
                            <label for="returnReasonTextarea" class="ml-1 font-weight-normal">Reason</label>
                            <textarea class="form-control" id="returnReasonTextarea" rows="4"></textarea>
                            <div class="invalid-feedback">
                                Feedback message
                            </div>
                        </div>

                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn bg-dark text-white" data-dismiss="modal">Close</button>
                    <form action="#" id="confirm-return-order" data-orderId="<%= order[0]._id %>" data-itemId="<%= order[0].orderItems._id %>" data-action="<%=allowedAction%>">
                        <button type="submit" class="btn text-danger"><%= allowedAction %> Order</button>
                    </form>
                </div>
              </div>
            </div>
        </div>

