    <script type="module">
        
        //remove from wishlist
        import {emptyFieldCheck, showAlert, triggerToast} from "/assets/js/fetch/validationHelpers.js"

        
        document.getElementById("confirm-return-order").addEventListener("submit", async function(e){

            e.preventDefault();
            
            const orderId = this.getAttribute("data-orderId");
            const itemId = this.getAttribute("data-itemId");
            const action = (this.getAttribute("data-action")).toLowerCase();
            let returnReason = document.querySelector('[name="returnReason"]:checked')?.value;

            if(returnReason === "other") {
                if (!emptyFieldCheck('submit', document.getElementById('returnReasonTextarea'))) {
                    return;
                } else {
                    returnReason = document.getElementById('returnReasonTextarea').value;
                }
            }

            console.log(orderId, itemId, action, returnReason);
            
            const response = await fetch(`/api/user/order/${orderId}/item/${itemId}/${action}`, {
                method : "PATCH",
                headers : {"Content-Type" : "application/json"},
                body: JSON.stringify({returnReason})
            });

            const data = await response.json();
            if (!data.success) {
                triggerToast("failure", data.error || "Sorry something wrong at our end");
            } else {
                triggerToast("success", data.message || "Return request submitted");
            }
            // showAlert(data, document.getElementById("order-alert"));

            setTimeout(() => {
                location.href = `/api/user/order/${orderId}/item/${itemId}`;
            }, 500)

        })      
        

    </script>
    <script src="/assets/js/jquery.min.js"></script>
    <script>
        $('input[name="returnReason"]').on('change', function () {
            const value = $('input[name="returnReason"]:checked').val();
            $('#returnReasonTextarea-div').toggleClass('d-none', value !== 'other');
        });

        $('#return-order-modal').on('hidden.bs.modal', function () {
            const modal = $(this);
            modal.find('.is-invalid, .is-valid').removeClass('is-invalid is-valid');
            // modal.find('input:radio').prop('checked', false);
            // modal.find('input, textarea').val('');
            // modal.find('#returnReasonTextarea-div').addClass('d-none');
        });


    </script>
