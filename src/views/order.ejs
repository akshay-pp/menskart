<body>
    <div class="page-wrapper">
        
        <%- include("./partials/user/header") %>

        <main class="main">
        	<div class="page-header text-center" style="background-image: url('/assets/images/page-header-bg.jpg')">
        		<div class="container">
        			<h1 class="page-title">Shopping Cart<span>Shop</span></h1>
        		</div><!-- End .container -->
        	</div><!-- End .page-header -->
            <nav aria-label="breadcrumb" class="breadcrumb-nav">
                <div class="container">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="index.html">Home</a></li>
                        <li class="breadcrumb-item"><a href="#">Shop</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Shopping Cart</li>
                    </ol>
                </div><!-- End .container -->
            </nav><!-- End .breadcrumb-nav -->

            <div class="page-content">
                <div class="alert alert-danger" style="display: none" id="order-alert" role="alert">
                    A simple danger alert—check it out!
                </div>
            	<div class="cart">
	                <div class="container">
	                	<div class="row">
	                		<div class="col-lg-9">
	                			<table class="table table-cart table-mobile">
									<thead>
										<tr>
											<th>Product</th>
											<th>Price</th>
											<th>Quantity</th>
											<th>Total</th>
											<th></th>
										</tr>
									</thead>

									<tbody>
                                        
                                            <tr>
                                                <td class="product-col">
                                                    <div class="product">
                                                        <figure class="product-media">
                                                            <a href="/api/user/products/<%= order[0].orderItems.product%>">
                                                                <img src="/<%= order[0].productData.images[0] %>" alt="Product image">
                                                            </a>
                                                        </figure>

                                                        <h3 class="product-title">
                                                            <a href="/api/user/products//<%= order[0].orderItems.product%>"><%= order[0].productData.productname %></a>
                                                        </h3><!-- End .product-title -->
                                                    </div><!-- End .product -->
                                                </td>
                                                <td class="price-col">₹<%= order[0].orderItems.price%></td>
                                                <td class="price-col"><%= order[0].orderItems.quantity%></td>
                                                <td class="total-col">₹<%= order[0].orderItems.price * order[0].orderItems.quantity %></td>
                                                <%# if (order.orderStatus == "delivered") { %>
                                                    <!-- <td><button class="btn-remove text-danger">return</button></td> -->
                                                <%# } else { %>
                                                    <!-- <td><button class="btn-remove text-danger">return</button></td> -->
                                                <%# } %>
                                            </tr>
                                        
									</tbody>
								</table><!-- End .table table-wishlist -->
                                
	                			<div class="cart-bottom">
                                    <div class="cart-discount">
                                        <a data-toggle="modal" id="return-button" data-target="#return-order-modal" data-action="<%= allowedAction %>" class="btn btn-danger px-4 text-white <%= allowedAction ? "" : "d-none" %>" ><span class="text-uppercase"><%= allowedAction ? `${allowedAction} Order` : `Order ${order[0].orderItems.status}`%></span><i class="icon-close"></i></a>
			            			</div><!-- End .cart-discount -->
                                    
			            			<a href="#" class="btn btn-outline-dark-2"><span>UPDATE CART</span><i class="icon-refresh"></i></a>
		            			</div><!-- End .cart-bottom -->
                                
                                <% if (otherItemsInOrder.length) { %>
                                    <div class="mt-2">
                                        <h6>Other items in this order</h6>
                                        <div class="form-check border rounded col-sm-12 mb-1 address">
                                            <table class="table table-cart table-mobile">
                                                <tbody>
                                                    <% otherItemsInOrder.forEach(item => { %>
                                                        <tr>
                                                            <td class="product-col py-4">
                                                                <div class="product d-flex ">
                                                                    <div>
                                                                        <figure class="product-media">
                                                                            <a href="/api/user/order/<%= item._id %>/item/<%= item.itemId %>">
                                                                                <img src="/<%= item.productImage %>" alt="Product image">
                                                                            </a>
                                                                        </figure>
                                                                    </div>
                                                                    
                                                                    <div>
                                                                        <h3 class="product-title">
                                                                            <a href="/api/user/order/<%= item._id %>/item/<%= item.itemId %>"> <%= item.productName %> </a>
                                                                        </h3><!-- End .product-title -->
                                                                    </div>
                                                                </div><!-- End .product -->
                                                            </td>
                                                        </tr>
                                                    <% }) %>
                                                </tbody>
                                            </table><!-- End .table table-wishlist -->
                                        </div>
                                    </div>
                                <% } %>
	                		</div><!-- End .col-lg-9 -->
	                		<aside class="col-lg-3">
	                			<div class="summary summary-cart">
	                				<h3 class="summary-title">Cart Total</h3><!-- End .summary-title -->

	                				<table class="table table-summary">
	                					<tbody>
	                						<tr class="summary-subtotal">
	                							<td>Subtotal:</td>
	                							<td>₹<%= order[0].orderItems.price %></td>
	                						</tr><!-- End .summary-subtotal -->
	                						<!-- <tr class="summary-shipping">
	                							<td>Shipping:</td>
	                							<td>&nbsp;</td>
	                						</tr> -->

	                						<!-- <tr class="summary-shipping-row">
	                							<td>
													<div class="custom-control custom-radio">
														<input type="radio" id="free-shipping" name="shipping" class="custom-control-input">
														<label class="custom-control-label" for="free-shipping">Free Shipping</label>
													</div>
	                							</td>
	                							<td>$0.00</td>
	                						</tr> -->

	                						<!-- <tr class="summary-shipping-row">
	                							<td>
	                								<div class="custom-control custom-radio">
														<input type="radio" id="standart-shipping" name="shipping" class="custom-control-input">
														<label class="custom-control-label" for="standart-shipping">Standart:</label>
													</div>
	                							</td>
	                							<td>$10.00</td>
	                						</tr>

	                						<tr class="summary-shipping-row">
	                							<td>
	                								<div class="custom-control custom-radio">
														<input type="radio" id="express-shipping" name="shipping" class="custom-control-input">
														<label class="custom-control-label" for="express-shipping">Express:</label>
													</div>
	                							</td>
	                							<td>$20.00</td>
	                						</tr>

	                						<tr class="summary-shipping-estimate">
	                							<td>Estimate for Your Country<br> <a href="dashboard.html">Change address</a></td>
	                							<td>&nbsp;</td>
	                						</tr> -->

	                						<tr class="summary-total">
	                							<td>Total:</td>
	                							<td>₹<%= order[0].orderItems.price %></td>
	                						</tr><!-- End .summary-total -->
	                					</tbody>
	                				</table><!-- End .table table-summary -->

	                				<a href='/api/user/order/<%= orderData._id %>/item/<%= orderData.orderItems._id %>/invoice' class="btn btn-outline-primary-2 btn-order btn-block">PRINT INVOICE</a>
	                			</div><!-- End .summary -->

                            <div class="card card-dashboard">
                                <div class="card-body">
                                    <h6>Shipping Details</h6>
                                    <p><%= orderData.addressData.name%>  <br>
                                        <%= orderData.addressData.phone%> <br>
                                        <%= orderData.addressData.address%><br>
                                        <%= orderData.addressData.phone%><br>
                                        <%= orderData.addressData.city%><br>
                                        <%= orderData.addressData.state%><br>
                                    </p>
                                </div><!-- End .card-body -->
                            </div><!-- End .card-dashboard -->    

		            			<a href="/api/user/products" class="btn btn-outline-dark-2 btn-block mb-3"><span>CONTINUE SHOPPING</span><i class="icon-refresh"></i></a>
