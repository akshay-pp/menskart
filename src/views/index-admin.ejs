                            <div class="table-responsive">
                                <table class="table align-middle table-nowrap mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th scope="col" class="text-center">
                                                <div class="form-check align-middle">
                                                    <input class="form-check-input" type="checkbox" id="transactionCheck01" />
                                                    <label class="form-check-label" for="transactionCheck01"></label>
                                                </div>
                                            </th>
                                            <th class="align-middle" scope="col">Order ID</th>
                                            <th class="align-middle" scope="col">Billing Name</th>
                                            <th class="align-middle" scope="col">Date</th>
                                            <th class="align-middle" scope="col">Total</th>
                                            <th class="align-middle" scope="col">Order Status</th>
                                            <th class="align-middle" scope="col">Payment Method</th>
                                            <th class="align-middle" scope="col">View Details</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% latestOrders.forEach(order => {%>
                                            <tr>
                                                <td class="text-center">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="transactionCheck02" />
                                                        <label class="form-check-label" for="transactionCheck02"></label>
                                                    </div>
                                                </td>
                                                <td><a href="/api/admin/orders/<%= order._id %>" class="fw-bold">#<%= order._id.toString().slice(12) %></a></td>
                                                <td><%= order.owner.fullname %></td>
                                                <td><b><%= new Date(order.createdAt).toLocaleString("en-IN", { 
                                                    day: "numeric", 
                                                    month: "short", 
                                                    year: "numeric", 
                                                    hour: "numeric", 
                                                    minute: "numeric", 
                                                    hour12: true 
                                                }).replace(" at", ", ") %></b></td>
                                                <td>₹<%= order.totalPrice %></td>
                                                <td>
                                                    <% if (order.orderStatus == "created"){ %>
                                                        <span class="badge rounded-pill alert-dark">Created</span>
                                                    <% } else if (order.orderStatus == "processing") { %>
                                                        <span class="badge rounded-pill alert-warning">Processing</span>
                                                    <% } else if (order.orderStatus == "shipped") { %>
                                                        <span class="badge rounded-pill alert-info">Shipped</span>
                                                    <% } else if (order.orderStatus == "delivered") { %>
                                                        <span class="badge rounded-pill alert-success">Delivered</span>
                                                    <% } else if (order.orderStatus == "cancelled") { %>
                                                        <span class="badge rounded-pill alert-danger">Cancelled</span>
                                                    <% } %>

                                                    <!-- <span class="badge badge-pill badge-soft-success">Paid</span> -->
                                                </td>
                                                <td><i class="material-icons md-payment font-xxl text-muted mr-5"></i> <%= order.paymentInfo.mode %></td>
                                                <td>
                                                    <a href="/api/admin/orders/<%= order._id %>" class="btn btn-xs"> View details</a>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <!-- table-responsive end// -->
                    </div>
                </div>
            </section>
            <!-- content-main end// -->
            <footer class="main-footer font-xs">
                <div class="row pb-30 pt-15">
                    <div class="col-sm-6">
                        <script>
                            document.write(new Date().getFullYear());
                        </script>
                        &copy; Nest - HTML Ecommerce Template .
                    </div>
                    <div class="col-sm-6">
                        <div class="text-sm-end">All rights reserved</div>
                    </div>
                </div>
            </footer>
        </main>

        <script>
            function handleIntervalChange(select) {
                const customRange = document.getElementById('custom-date-range');
                // const hiddenInput = document.getElementById('intervalInput');

                // if (hiddenInput) {
                //     hiddenInput.value = select.value;
                // }
        
                if (select.value === 'custom') {
                    customRange.style.display = 'flex';
                } else {
                    customRange.style.display = 'none';
                    select.form.submit();
                }
            }
        
            
            window.addEventListener('DOMContentLoaded', () => {
                const interval = "<%= interval %>";
                if (interval === 'custom') {
                    document.getElementById('custom-date-range').style.display = 'flex';
                }
            });
        </script>
        

        <script src="/assets/js/vendors/jquery-3.6.0.min.js"></script>
        <script src="/assets/js/vendors/bootstrap.bundle.min.js"></script>
        <script src="/assets/js/vendors/select2.min.js"></script>
        <script src="/assets/js/vendors/perfect-scrollbar.js"></script>
        <script src="/assets/js/vendors/jquery.fullscreen.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
        <script>
            const labels = <%- JSON.stringify(chartData.labels) %>;
            const data = <%- JSON.stringify(chartData.data) %>;

            const options = {
                chart: {
                    type: 'line',
                    height: 350,
                    toolbar: { show: false }
                },
                stroke: {
                    curve: 'smooth'
                },
                series: [{
                    name: 'Orders',
                    data: data
                }],
                xaxis: {
                    categories: labels,
                    labels: {
                        show: false
                    }
                },
                colors: ['#00BFFF']
            };

            const chart = new ApexCharts(document.querySelector("#splineChart"), options);
            chart.render();
        </script>
        <script src="/assets/js/vendors/chart.js"></script>
        <!-- Main Script -->
        <script src="/assets/js/main.js?v=1.1" type="text/javascript"></script>
        <script src="/assets/js/custom-chart.js" type="text/javascript"></script>
    </body>
</html>
