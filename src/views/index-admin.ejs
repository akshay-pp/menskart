    <body>        
        <div class="screen-overlay"></div>
        
        <%- include(`./partials/admin/aside`) %>

        <main class="main-wrap">

            <%- include(`./partials/admin/header`) %>

            <section class="content-main">
                <div class="content-header">
                    <div>
                        <h2 class="content-title card-title">Dashboard</h2>
                        <p>Whole data about your business here</p>
                    </div>
                    
                    <div>
                        <form action="/api/admin/generateSalesReport" method="get" id="generateReportForm">
                            <input type="hidden" name="interval" id="intervalInput" value="<%= interval %>">
                            <input type="hidden" name="start" id="startDate" class="form-control mx-2" value="<%= start || '' %>">
                            <input type="hidden" name="end" id="endDate" class="form-control mx-2" value="<%= end || '' %>">
                            <button type="submit" class="btn btn-primary"><i class="text-muted material-icons md-post_add"></i>Create report</button>
                        </form>
                    </div>
                </div>

                <div class="col-md-12 col-12 mb-3 d-flex">
                    <div class="custom_select">
                        <form method="GET" action="/api/admin/dashboard" class="d-flex justify-content-between align-items-center">
                            <div class>
                                <select class="form-select select-nice" name="interval" onchange="handleIntervalChange(this)">
                                    <option value="daily" <% if (interval == 'daily') { %> selected <% } %> >Today</option>
                                    <option value="weekly" <% if (interval == 'weekly') { %> selected <% } %> >This Week</option>
                                    <option value="monthly" <% if (interval == 'monthly') { %> selected <% } %> >This Month</option>
                                    <option value="yearly" <% if (interval == 'yearly') { %> selected <% } %> >This Year</option>
                                    <option value="all-time" <% if (interval == 'all-time') { %> selected <% } %> >All time</option>
                                    <option value="custom" <% if (interval == 'custom') { %> selected <% } %>>Custom</option>
                                </select>
                            </div>

                            <div id="custom-date-range" style="display: none; margin-top: 10px;" class="justify-content-center">
                                <label for="start" class="mx-2">Start Date:</label>
                                <input type="date" name="start" id="start" class="form-control mx-2" value="<%= start || '' %>">
                        
                                <label for="end" class="mx-2">End Date:</label>
                                <input type="date" name="end" id="end" class="form-control mx-2" value="<%= end || '' %>">
                        
                                <button type="submit" class="btn btn-primary mx-2">Apply</button>
                            </div>
                        </form>
                    </div>
                </div>
                <div class="row">
                    <div class="col-lg-3">
                        <div class="card card-body mb-4">
                            <article class="icontext">
                                <span class="icon icon-sm rounded-circle bg-primary-light"><i class="text-primary material-icons md-monetization_on"></i></span>
                                <div class="text">
                                    <h6 class="mb-1 card-title">Revenue</h6>
                                    <span>₹<%= data.totalRevenue  %></span>
                                    <span class="text-sm"> Shipping fees are not included </span>
                                </div>
                            </article>
                        </div>
                    </div>
                    <div class="col-lg-3">
                        <div class="card card-body mb-4">
                            <article class="icontext">
                                <span class="icon icon-sm rounded-circle bg-success-light"><i class="text-success material-icons md-local_shipping"></i></span>
                                <div class="text">
                                    <h6 class="mb-1 card-title">Orders</h6>
                                    <span><%= data.totalOrders %></span>
                                    <span class="text-sm"> Excluding orders in transit </span>
                                </div>
                            </article>
                        </div>
                    </div>
                    <div class="col-lg-3">
                        <div class="card card-body mb-4">
                            <article class="icontext">
                                <span class="icon icon-sm rounded-circle bg-warning-light"><i class="text-warning material-icons md-qr_code"></i></span>
                                <div class="text">
                                    <h6 class="mb-1 card-title">Products Sold</h6>
                                    <span><%=data.productSales %></span>
                                    <span class="text-sm"> In 19 Categories </span>
                                </div>
                            </article>
                        </div>
                    </div>
                    <div class="col-lg-3">
