<body>
    <div class="page-wrapper">

        <%- include("./partials/user/header") %>

        <main class="main">
        	<div class="page-header text-center" style="background-image: url('/assets/images/page-header-bg.jpg')">
        		<div class="container">
        			<h1 class="page-title">Wishlist<span>Shop</span></h1>
        		</div><!-- End .container -->
        	</div><!-- End .page-header -->
            <nav aria-label="breadcrumb" class="breadcrumb-nav">
                <div class="container">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="index.html">Home</a></li>
                        <li class="breadcrumb-item"><a href="#">Shop</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Wishlist</li>
                    </ol>
                </div><!-- End .container -->
            </nav><!-- End .breadcrumb-nav -->

            <div class="page-content">
                <div class="alert alert-danger" style="display: none" id="wishlist-alert" role="alert">
                    A simple danger alert—check it out!
                </div>
            	<div class="container">
					<%# if(isEmpty) { %>

                        <div class="<%=isEmpty ? 'd-flex' : 'd-none' %>  flex-column align-items-center" id="empty-wishlist-div">
                                <div>
                                    <img src="/assets/images/Empty-cuate.svg" class="img-fluid" alt="Empty Cart Image" style="width: 400px; height: auto;">
                                </div>
                                <div class="d-flex flex-column align-items-center">
                                    <h3 class="mb-0">Your wishlist is currently empty!</h3>
                                    <p>checkout some cool products! 👇 </p>
                                    <a href="/api/user/products" class="my-4 btn btn-primary btn-rounded rounded-pill">SHOP COOL STUFF</a>
                                </div>
                        </div>

                    <%# } else { %>

                        <table class="<%=!isEmpty ? '' : 'd-none' %> table table-wishlist table-mobile" id="wishlist-table">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Price</th>
                                    <th>Stock Status</th>
                                    <th></th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody>
                                <% wishlist?.products?.forEach(product => { %>
                                    <tr id="<%= product._id %>-wishlist">
                                        <td class="product-col">
                                            <div class="product">
                                                <figure class="product-media">
                                                    <a href="#">
                                                        <img src="/<%= product.images[0] %>" alt="Product image">
                                                    </a>
                                                </figure>

                                                <h3 class="product-title">
                                                    <a href="#"><%= product.productname %></a>
                                                </h3><!-- End .product-title -->
                                            </div><!-- End .product -->
                                        </td>
                                        <td class="price-col">₹<%= product.price %></td>
                                        <td class="stock-col">
                                            <span class="<%= product.stock > 10 ? "in-stock" : "out-of-stock" %>">
                                            <%= product.stock > 10 ? "In Stock" : "Low in stock"  %></span>
                                        </td>
                                        <!-- <td class="action-col">
                                            <div class="dropdown">
                                            <button class="btn btn-block btn-outline-primary-2" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                <i class="icon-list-alt"></i>Select Options
                                            </button>

                                            <div class="dropdown-menu">
                                                <a class="dropdown-item" href="#">First option</a>
                                                <a class="dropdown-item" href="#">Another option</a>
                                                <a class="dropdown-item" href="#">The best option</a>
                                            </div>
                                            </div>
                                        </td> -->
                                        <td class="action-col">
                                            <form action="#" class="add-to-cart-form">
                                                <input type="hidden" name="productId" value="<%= product._id %>">
                                                <input type="hidden" name="referer" value="wishlist">
                                                <button name="add-to-cart-btn" class="btn btn-block btn-outline-primary-2"><i class="icon-cart-plus"></i>Move to Cart</button>
                                            </form>
                                            
                                        </td>
                                        <td class="remove-col">
                                            <a href="#" data-toggle="modal" data-target="#remove-from-wishlist-modal" class="btn btn-remove text-danger" name="removeFromWishlistButton" data-id="<%= product._id %>"><i class="icon-close"></i></a>
                                            <!-- <button class="btn btn-remove text-danger"><i class="icon-close"></i></button> -->
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
					    </table><!-- End .table table-wishlist -->
                        <div class="wishlist-share d-none">
                            <div class="social-icons social-icons-sm mb-2 mt-4">
                                <label class="social-label">Share on:</label>
                                <a href="#" class="social-icon" title="Facebook" target="_blank"><i class="icon-facebook-f"></i></a>
                                <a href="#" class="social-icon" title="Twitter" target="_blank"><i class="icon-twitter"></i></a>
                                <a href="#" class="social-icon" title="Instagram" target="_blank"><i class="icon-instagram"></i></a>
                                <a href="#" class="social-icon" title="Youtube" target="_blank"><i class="icon-youtube"></i></a>
                                <a href="#" class="social-icon" title="Pinterest" target="_blank"><i class="icon-pinterest"></i></a>
                            </div><!-- End .soial-icons -->
                        </div><!-- End .wishlist-share -->

                    <%# } %>
            	</div><!-- End .container -->
            </div><!-- End .page-content -->
        </main><!-- End .main -->

        <!-- remove from wishlist modal -->
        <div class="modal fade" id="remove-from-wishlist-modal" tabindex="-1" role="dialog" aria-labelledby="removeFromWishlistModal" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="remove-wishlist-header">Remove the product from wishlist?</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                </div>
                <div class="modal-body my-3">
                  <span class="mx-3">are you sure you want to remove this product from your wishlist?</span>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">Close</button>
                    <form action="#" id="confirm-remove-from-wishlist">
                        <button type="submit" class="btn btn-danger">Remove Product</button>
                    </form>
                </div>
              </div>
            </div>
        </div>

        <!-- toast -->
        <div class="toast" id="wishlist-page-toast" role="alert" aria-live="assertive" aria-atomic="true" style="position: fixed; bottom: 2rem; right: 1rem; z-index: 1055; width: 400px;">
            <div class="toast-header bg-dark text-white justify-content-between" id="toast-header">

                <div class="d-flex p-4">
                    
                    <svg id="success-toast" class="d-none toast-icon" fill="#28a745" width="20px" viewBox="0 0 32 32" version="1.1" xmlns="http://www.w3.org/2000/svg">
                        <title>checkmark</title>
                        <path d="M16 3c-7.18 0-13 5.82-13 13s5.82 13 13 13 13-5.82 13-13-5.82-13-13-13zM23.258 12.307l-9.486 9.485c-0.238 0.237-0.623 0.237-0.861 0l-0.191-0.191-0.001 0.001-5.219-5.256c-0.238-0.238-0.238-0.624 0-0.862l1.294-1.293c0.238-0.238 0.624-0.238 0.862 0l3.689 3.716 7.756-7.756c0.238-0.238 0.624-0.238 0.862 0l1.294 1.294c0.239 0.237 0.239 0.623 0.001 0.862z"></path>
                    </svg>

                    <svg id="warning-toast" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" class="iconify iconify--emojione d-none toast-icon" width="20px" preserveAspectRatio="xMidYMid meet" fill="#000000" transform="rotate(0)"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path d="M5.9 62c-3.3 0-4.8-2.4-3.3-5.3L29.3 4.2c1.5-2.9 3.9-2.9 5.4 0l26.7 52.5c1.5 2.9 0 5.3-3.3 5.3H5.9z" fill="#ffce31"> </path> <g fill="#231f20"> <path d="M27.8 23.6l2.8 18.5c.3 1.8 2.6 1.8 2.9 0l2.7-18.5c.5-7.2-8.9-7.2-8.4 0"> </path> <circle cx="32" cy="49.6" r="4.2"> </circle> </g> </g></svg>


                    <svg id="failure-toast" class="d-none toast-icon" version="1.1"  fill="#DC3545" width="20px" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px"
                    viewBox="0 0 512 512" style="enable-background:new 0 0 512 512;" xml:space="preserve">
                        <g>
                            <g>
                                <path d="M256,0C114.615,0,0,114.615,0,256s114.615,256,256,256s256-114.615,256-256S397.385,0,256,0z M327.115,365.904
                                    L256,294.789l-71.115,71.115l-38.789-38.789L217.211,256l-71.115-71.115l38.789-38.789L256,217.211l71.115-71.115l38.789,38.789
                                    L294.789,256l71.115,71.115L327.115,365.904z"/>
                            </g>
                        </g>
                    </svg>

                    <span class="ml-3" id="toast-title" style="font-size: 14px;">Notification</span>

                </div>

                <button type="button" class="ml-2 mb-1 close" data-dismiss="toast" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        </div>

        <!-- footer -->
        <%- include("./partials/user/footer") %>
        
