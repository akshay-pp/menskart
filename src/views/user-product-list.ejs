    <!-- Plugins JS File -->
    <script>
        
        function sortBy() {
            const selectedSort = document.getElementById("sortby").value;
            const currentUrl = new URL(window.location.href);
    
            currentUrl.searchParams.set("page", "1");
            currentUrl.searchParams.set("sort", selectedSort);

            window.location.href = currentUrl.toString();
        }

        const checkboxes = document.querySelectorAll("[name='category[]']");
        
        const category = [];
        checkboxes.forEach(box => {
            box.addEventListener("change", function(){
                
                // console.log(box.checked ? "true" : "false");
                const currentUrl = new URL(window.location.href);
                const params = currentUrl.searchParams;
                console.log({searchParams: params.getAll('category')});
                const currentCategory = box.value;
                params.set("page", "1");
                
                if (box.checked) {

                    params.append('category', currentCategory);

                } else {

                    const updatedCategoryList = params.getAll('category').filter(item => item !== currentCategory);
                    params.delete('category');
                    updatedCategoryList.forEach(category => params.append('category', category))

                }

                window.location.href = currentUrl.toString();

            }) 
        })
        

    </script>
